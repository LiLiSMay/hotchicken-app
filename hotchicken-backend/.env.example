# ─────────────────────────────────────────────
# HOTCHICKEN BACKEND - Variables de Entorno
# Copia este archivo a .env y completa los valores
# ─────────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=tu_password_aqui
DB_NAME=hotchicken_db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT
JWT_SECRET=hotchicken_super_secret_jwt_key_cambiar_en_produccion
JWT_EXPIRES_IN=8h

# CORS - Origen del frontend React
FRONTEND_URL=http://localhost:5173
